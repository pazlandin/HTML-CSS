<!DOCTYPE html> 

<html lang="pt-br"> 

<head> 

<meta charset="UTF-8"> 

<title>To-Do List</title> 

 

<style> 

body { 

font-family: Arial; 

background-color: #f0f0f0; 

text-align: center; 

margin-top: 50px; 

} 

 

h1 { 

color: #333; 

} 

 

input { 

padding: 10px; 

width: 200px; 

} 

 

button { 

padding: 10px; 

background-color: #28a745; 

color: white; 

border: none; 

cursor: pointer; 

} 

 

button:hover { 

background-color: #218838; 

} 

 

ul { 

list-style: none; 

padding: 0; 

} 

 

li { 

background: white; 

margin: 10px auto; 

padding: 10px; 

width: 250px; 

border-radius: 5px; 

cursor: pointer; 

} 

 

.concluida { 

text-decoration: line-through; 

color: gray; 

background-color: #d4edda; 

} 

</style> 

</head> 

 

<body> 

 

<h1>Lista de Tarefas</h1> 

 

<input type="text" id="tarefaInput" placeholder="Digite uma tarefa"> 

<button onclick="adicionarTarefa()">Adicionar</button> 

 

<ul id="lista"></ul> 

 

<script> 

function adicionarTarefa() { 

let input = document.getElementById("tarefaInput"); 

let texto = input.value; 

 

if (texto === "") return; 

 

let li = document.createElement("li"); 

li.textContent = texto; 

 

li.onclick = function() { 

li.classList.toggle("concluida"); 

}; 

 

document.getElementById("lista").appendChild(li); 

 

input.value = ""; 

} 

</script> 

 

</body> 

</html> 
